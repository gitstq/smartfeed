# SmartFeed Configuration
# Copy this file to .env and modify the values

# Server Configuration
PORT=3456
HOST=127.0.0.1

# Database
DB_PATH=./data/smartfeed.db

# Feed Update Interval (cron expression)
# Default: every 30 minutes
UPDATE_CRON=*/30 * * * *

# AI Summary Configuration
# Set to 'true' to enable AI summaries (requires external AI API)
ENABLE_AI_SUMMARY=false
AI_API_KEY=your_api_key_here
AI_API_URL=https://api.openai.com/v1/chat/completions
AI_MODEL=gpt-3.5-turbo

# Maximum items to keep per feed
MAX_ITEMS_PER_FEED=100

# Default fetch timeout (milliseconds)
FETCH_TIMEOUT=10000

# User Agent for feed fetching
USER_AGENT=SmartFeed/1.0