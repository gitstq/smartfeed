{
  "name": "smartfeed",
  "version": "1.0.0",
  "description": "AI驱动的智能信息聚合与知识管理工具",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "dev": "node --watch src/index.js",
    "build": "pkg . --out-path=dist/",
    "build:win": "pkg . --targets=node20-win-x64 --out-path=dist/",
    "build:mac": "pkg . --targets=node20-macos-x64 --out-path=dist/",
    "build:linux": "pkg . --targets=node20-linux-x64 --out-path=dist/",
    "test": "node --test test/**/*.test.js",
    "lint": "eslint src/"
  },
  "keywords": [
    "rss",
    "feed",
    "ai",
    "knowledge-management",
    "aggregator",
    "information",
    "news",
    "summary",
    "local-first"
  ],
  "author": "gitstq",
  "license": "MIT",
  "bin": {
    "smartfeed": "./src/index.js"
  },
  "pkg": {
    "scripts": [
      "src/**/*.js",
      "public/**/*"
    ],
    "assets": [
      "public/**/*",
      "config/**/*"
    ]
  },
  "dependencies": {
    "express": "^4.18.2",
    "rss-parser": "^3.13.0",
    "better-sqlite3": "^9.4.3",
    "node-cron": "^3.0.3",
    "cheerio": "^1.0.0-rc.12",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.1",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "eslint": "^8.57.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}